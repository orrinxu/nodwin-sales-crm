# =============================================================================
# Environment Variables — Nodwin Sales CRM
# =============================================================================
# Copy this file to .env.local and fill in actual values.
# All required vars are validated at startup by lib/security/env.ts.
# =============================================================================

# -- Required (validated by Zod schema) ---------------------------------------

# Application display name (e.g. "Nodwin CRM")
NEXT_PUBLIC_APP_NAME=Nodwin CRM

# Public API base URL (must be a valid URL, e.g. "http://localhost:3001/api")
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Supabase project URL (must be a valid URL)
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon / public key
SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service-role key — server-side only, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase JWT secret (self-host: GoTrue's JWT_SECRET). Used to mint short-lived
# per-user JWTs for REST-API-token callers so RLS applies. Server-side only.
# The REST API (/api/v1/*) returns 503 until this is set. ROTATE the quick-start
# default before production — anyone with the default secret can mint any user's token.
# SUPABASE_JWT_SECRET=your-jwt-secret-here

# Postmark inbound webhook bearer token. Postmark does not HMAC-sign requests;
# instead, configure Postmark → Server → Webhooks → HttpHeaders to send
# X-Postmark-Webhook-Secret: <this value> with every inbound webhook delivery.
POSTMARK_WEBHOOK_SECRET=your-postmark-webhook-secret-here

# Incident kill switch for the inbound-email route. Set to true to make
# POST /api/webhooks/postmark short-circuit with 503 (Postmark holds and retries,
# so authentic mail is paused, not dropped). Leave unset/false in normal operation.
# INBOUND_EMAIL_DISABLED=false

# -- Optional (Zod defaults apply when unset) --------------------------------

# App base URL for OAuth callbacks (must be a valid URL, default: "http://localhost:3000")
APP_URL=http://localhost:3000

# Debug mode ("true" | "false" | "1" | "0", default: "false")
NEXT_PUBLIC_DEBUG=false

# Logging level ("debug" | "info" | "warn" | "error", default: "info")
NEXT_PUBLIC_LOG_LEVEL=info

# Environment label. Set to "local-preview" to skip auth and auto-login as admin.
# NEVER set this in production or committed env files.
NEXT_PUBLIC_ENV=

# -- Google Drive import (Picker) — optional -----------------------------------
# Enables the "Import from Drive" button on the Files module. Both are public
# browser values baked at BUILD time (NEXT_PUBLIC_*). Leave blank to hide the
# button. In Google Cloud: OAuth 2.0 Client (Web) with the app origin in
# Authorized JavaScript origins + drive.file on the consent screen; a Browser
# API key restricted to the Picker API + your referrer.
# NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
# NEXT_PUBLIC_GOOGLE_PICKER_API_KEY=

# -- Per-user Google OAuth token store (ORR-817 / ORR-773) — optional ----------
# At-rest key for encrypting stored Google access/refresh tokens (app-layer
# AES-256-GCM). Must be exactly 32 raw bytes, base64-encoded. Leave blank until
# per-user Google OAuth is wired — the app boots without it and only the token
# encryption path fails. Generate with:  openssl rand -base64 32
# GOOGLE_TOKEN_ENC_KEY=

# -- Google server-side OAuth2 (ORR-773) — optional ----------------------------
# Per-user authorization-code flow for server-side Google access (distinct from
# the browser Picker above and from the Drive service account). SERVER-ONLY
# secrets — do NOT prefix with NEXT_PUBLIC. Leave blank to keep the integration
# unwired. In Google Cloud: OAuth 2.0 Client (Web) with the redirect URI below
# added under "Authorized redirect URIs". The redirect URI must match exactly;
# conceptually it is ${APP_URL}/api/integrations/google/callback (env vars can't
# interpolate, so write the fully-resolved URL, e.g.
# http://localhost:3000/api/integrations/google/callback).
# GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# -- AI providers (all optional; only configured providers are used) ----------
# The AI router uses whichever providers have keys/URLs set. Each provider's
# model is overridable via its *_MODEL var (current Claude default: claude-sonnet-4-6).
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-1.5-pro
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# MOONSHOT_API_KEY=
# MOONSHOT_MODEL=moonshot-v1-8k
# OLLAMA_BASE_URL=
# OLLAMA_MODEL=llama3.2

# Generic OpenAI-compatible endpoint — drop in any compatible server (OpenAI,
# Ollama's /v1, LM Studio, llama.cpp, a self-hosted Qwen box, etc.) without a
# code change. Set the base URL up to and including /v1.
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:1234/v1
# OPENAI_COMPATIBLE_MODEL=gpt-4o-mini
# OPENAI_COMPATIBLE_API_KEY=
