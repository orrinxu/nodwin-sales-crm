# =============================================================================
# Environment Variables — Nodwin Sales CRM
# =============================================================================
# Copy this file to .env.local and fill in actual values.
# All required vars are validated at startup by lib/security/env.ts.
# =============================================================================

# -- Required (validated by Zod schema) ---------------------------------------

# Application display name (e.g. "Nodwin CRM")
NEXT_PUBLIC_APP_NAME=Nodwin CRM

# Public API base URL (must be a valid URL, e.g. "http://localhost:3001/api")
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Supabase project URL (must be a valid URL)
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon / public key
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service-role key — server-side only, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Postmark inbound webhook bearer token. Postmark does not HMAC-sign requests;
# instead, configure Postmark → Server → Webhooks → HttpHeaders to send
# X-Postmark-Webhook-Secret: <this value> with every inbound webhook delivery.
POSTMARK_WEBHOOK_SECRET=your-postmark-webhook-secret-here

# -- Optional (Zod defaults apply when unset) --------------------------------

# Debug mode ("true" | "false", default: "false")
NEXT_PUBLIC_DEBUG=false

# Logging level ("debug" | "info" | "warn" | "error", default: "info")
NEXT_PUBLIC_LOG_LEVEL=info
