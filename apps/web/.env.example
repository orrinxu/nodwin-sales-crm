# =============================================================================
# Environment Variables — Nodwin Sales CRM
# =============================================================================
# Copy this file to .env.local and fill in actual values.
# All required vars are validated at startup by lib/security/env.ts.
# =============================================================================

# -- Required (validated by Zod schema) ---------------------------------------

# Application display name (e.g. "Nodwin CRM")
NEXT_PUBLIC_APP_NAME=Nodwin CRM

# Public API base URL (must be a valid URL, e.g. "http://localhost:3001/api")
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Supabase project URL (must be a valid URL)
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon / public key
SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service-role key — server-side only, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Postmark inbound webhook bearer token. Postmark does not HMAC-sign requests;
# instead, configure Postmark → Server → Webhooks → HttpHeaders to send
# X-Postmark-Webhook-Secret: <this value> with every inbound webhook delivery.
POSTMARK_WEBHOOK_SECRET=your-postmark-webhook-secret-here

# -- Optional (Zod defaults apply when unset) --------------------------------

# App base URL for OAuth callbacks (must be a valid URL, default: "http://localhost:3000")
APP_URL=http://localhost:3000

# Debug mode ("true" | "false" | "1" | "0", default: "false")
NEXT_PUBLIC_DEBUG=false

# Logging level ("debug" | "info" | "warn" | "error", default: "info")
NEXT_PUBLIC_LOG_LEVEL=info

# Environment label. Set to "local-preview" to skip auth and auto-login as admin.
# NEVER set this in production or committed env files.
NEXT_PUBLIC_ENV=

# -- AI providers (all optional; only configured providers are used) ----------
# The AI router uses whichever providers have keys/URLs set. Each provider's
# model is overridable via its *_MODEL var (current Claude default: claude-sonnet-4-6).
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-1.5-pro
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# MOONSHOT_API_KEY=
# MOONSHOT_MODEL=moonshot-v1-8k
# OLLAMA_BASE_URL=
# OLLAMA_MODEL=llama3.2

# Generic OpenAI-compatible endpoint — drop in any compatible server (OpenAI,
# Ollama's /v1, LM Studio, llama.cpp, a self-hosted Qwen box, etc.) without a
# code change. Set the base URL up to and including /v1.
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:1234/v1
# OPENAI_COMPATIBLE_MODEL=gpt-4o-mini
# OPENAI_COMPATIBLE_API_KEY=
