# deploy/app.env.example — RUNTIME environment for the `app` container (staging VPS).
#
# Copy to `app.env` beside your compose file on the VPS and fill in real values.
# Do NOT commit app.env (it is gitignored) — it contains the service-role key.
#
# BUILD-TIME vs RUNTIME (important):
#   NEXT_PUBLIC_* are inlined into the CLIENT bundle at BUILD time. They are set
#   as GitHub Actions build-args (from repo *vars*), NOT here — they are already
#   baked into the image. The ONE exception is NEXT_PUBLIC_API_URL: the server
#   (lib/security/env.ts) parses it at runtime and requires it, so it must ALSO
#   be present here, set to the SAME value used at build.

# ── Required — the app will not boot without these ──────────────────────────
SUPABASE_URL=https://<staging-supabase-host>
SUPABASE_ANON_KEY=<staging anon / publishable key>
SUPABASE_SERVICE_ROLE_KEY=<staging service-role / secret key>     # SECRET
POSTMARK_WEBHOOK_SECRET=<postmark inbound webhook secret>          # SECRET
NEXT_PUBLIC_API_URL=https://<staging-app-host>/api                 # must equal the build-arg

# ── Recommended ─────────────────────────────────────────────────────────────
APP_URL=https://<staging-app-host>     # base URL used in outbound email links
# NODE_ENV=production                    # the image already sets this

# ── Optional: outbound email (Resend) ───────────────────────────────────────
# RESEND_API_KEY=
# RESEND_DOMAIN=

# ── Optional: Slack notifications ───────────────────────────────────────────
# SLACK_BOT_TOKEN=

# ── Optional: document ingestion / embeddings (ORR-620) ─────────────────────
# EMBEDDINGS_BASE_URL=
# EMBEDDINGS_MODEL=
# EMBEDDINGS_API_KEY=
# INGESTION_CRON_SECRET=

# ── Optional: RAG generation fallback (ORR-634; DB ai_settings takes priority)
# GENERATION_BASE_URL=
# GENERATION_MODEL=
# GENERATION_API_KEY=

# ── Optional: AI provider keys (ORR-635; DB ai_providers takes priority) ────
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=
# GOOGLE_API_KEY=
# GEMINI_MODEL=
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=
# MOONSHOT_API_KEY=
# MOONSHOT_MODEL=
# OPENAI_COMPATIBLE_BASE_URL=
# OPENAI_COMPATIBLE_MODEL=
# OPENAI_COMPATIBLE_API_KEY=
# OLLAMA_BASE_URL=
# OLLAMA_MODEL=
