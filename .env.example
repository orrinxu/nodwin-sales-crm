# ─────────────────────────────────────────────
# Nodwin CRM — environment variables
# ─────────────────────────────────────────────
# Copy this file to .env.local for local development.
# Replace placeholders with your actual values.
# Never commit real secrets to the repository.
#
# The single source of truth is apps/web/lib/security/env-schema.ts — every var
# below is declared there. Required vars are uncommented; optional ones are
# commented out. Keep the two in sync.
# ─────────────────────────────────────────────

# ─── Supabase (required) ──────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
# SUPABASE_JWT_SECRET=<jwt-secret>          # only needed for local JWT verification

# ─── App / URLs (required) ────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
# APP_URL=http://localhost:3000             # server-side base URL (default: http://localhost:3000)
# NEXT_PUBLIC_APP_NAME=Nodwin CRM
# NODE_ENV=development
# NEXT_PUBLIC_ENV=local
# NEXT_PUBLIC_DEBUG=false
# NEXT_PUBLIC_LOG_LEVEL=info                # debug | info | warn | error

# ─── Inbound email (Postmark) — required ──────
POSTMARK_WEBHOOK_SECRET=<postmark-webhook-secret>
# INBOUND_EMAIL_DISABLED=false
# RESEND_API_KEY=<resend-api-key>           # transactional/outbound email (optional)
# RESEND_DOMAIN=<your-domain>

# ─── Slack (optional) ─────────────────────────
# SLACK_BOT_TOKEN=xoxb-<your-bot-token>

# ─── Google Workspace / Drive (optional) ──────
# NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=<client-id>.apps.googleusercontent.com
# NEXT_PUBLIC_GOOGLE_PICKER_API_KEY=<picker-api-key>
# GOOGLE_SERVICE_ACCOUNT_KEY=<service-account-json>   # Drive server-side sync (ORR-698)
# GOOGLE_WORKSPACE_ADMIN_SUBJECT=<admin@your-domain>
# GOOGLE_DRIVE_SHARED_DRIVE_ID=<shared-drive-id>
# DRIVE_SYNC_CRON_SECRET=<cron-secret>

# ─── AI: RAG pipeline (optional) ──────────────
# EMBEDDINGS_BASE_URL=https://api.openai.com/v1
# EMBEDDINGS_MODEL=text-embedding-3-small
# EMBEDDINGS_API_KEY=<key>
# GENERATION_BASE_URL=https://api.openai.com/v1
# GENERATION_MODEL=gpt-4o-mini
# GENERATION_API_KEY=<key>
# TRANSCRIPTION_BASE_URL=https://api.openai.com/v1
# TRANSCRIPTION_MODEL=whisper-1
# TRANSCRIPTION_API_KEY=<key>
# INGESTION_CRON_SECRET=<cron-secret>

# ─── AI: chat providers (optional) ────────────
# Each provider is enabled when its API key / base URL is present. MODEL vars
# override the built-in default model per provider.
# ANTHROPIC_API_KEY=<anthropic-api-key>
# ANTHROPIC_MODEL=claude-sonnet-4-6
# GOOGLE_API_KEY=<google-ai-api-key>
# GEMINI_MODEL=gemini-1.5-pro
# DEEPSEEK_API_KEY=<deepseek-api-key>
# DEEPSEEK_MODEL=deepseek-chat
# MOONSHOT_API_KEY=<moonshot-api-key>
# MOONSHOT_MODEL=moonshot-v1-8k
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:1234/v1
# OPENAI_COMPATIBLE_MODEL=gpt-4o-mini
# OPENAI_COMPATIBLE_API_KEY=<key>
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
