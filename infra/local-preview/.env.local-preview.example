# Environment template for local LAN preview deployment on the AMD GPU server.
# Copy this file to .env.local-preview and fill in real values.
# Never commit the .env.local-preview file with real values.

# Application name
NEXT_PUBLIC_APP_NAME=Nodwin CRM

# Public API URL — the Next.js app serves its own API at this port
NEXT_PUBLIC_API_URL=http://192.168.88.51:3030/api

# Supabase — running locally on the AMD GPU server via Docker
# URL: the local Supabase API gateway
SUPABASE_URL=http://192.168.88.51:54321
# Public anon key — find in Supabase Studio > Settings > API
SUPABASE_ANON_KEY=
# Service role key — keep secret, never commit the real value
SUPABASE_SERVICE_ROLE_KEY=

# Feature flags
NEXT_PUBLIC_DEBUG=false
NEXT_PUBLIC_LOG_LEVEL=info

# Custom configuration (JSON string, optional)
# Example: {"theme":"dark","featureX":true}
NEXT_PUBLIC_CUSTOM_CONFIG={}
