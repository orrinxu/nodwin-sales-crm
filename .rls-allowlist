# .rls-allowlist — Legitimate exceptions for RLS policy linter
#
# Format per line:
#   - file_pattern:line_pattern   (scoped to matching files)
#   - line_pattern                (global, applies to all files)
#
# Blank lines and lines starting with # are ignored.
# Patterns are grep -E extended regex.

# ── auth_allowed_domains ───────────────────────────────────────────────────────
# This table is queried by the Supabase Auth Hook Edge Function on every
# sign-up. The policies are restricted to service_role, which bypasses RLS
# in Supabase by default. These explicit policies are documentation only.
# No anon/authenticated user can access this table.
.*auth_allowed_domains.*:USING \(true\)
.*auth_allowed_domains.*:WITH CHECK \(true\)

# ── audit_log ──────────────────────────────────────────────────────────────────
# All authenticated users can read audit logs for record history.
# This is intentional: audit_log is append-only and users need to see
# history for records they own. Write access is admin-only.
.*audit.*:auth\.uid\(\) IS NOT NULL

# ── opportunity_splits / opportunity_team_members ──────────────────────────────
# FOR ALL is used for admin-only write policies on junction tables.
# These are safe because the USING/WITH CHECK clauses restrict to admin role.
.*opportunit.*:FOR ALL

# ── money_helpers ──────────────────────────────────────────────────────────────
# False positive: comment contains the words "for all" but there is no RLS
# policy in this migration.
.*money_helpers.*:FOR ALL

# ── ai_usage ───────────────────────────────────────────────────────────────────
# ai_daily_caps is a configuration table. All authenticated users need read
# access to see their daily cap. Write access is admin-only.
.*ai_usage.*:auth\.uid\(\) IS NOT NULL

# ── currencies ─────────────────────────────────────────────────────────────────
# Currencies is a read-only lookup table. All authenticated users need read
# access to reference currency codes. Write access is admin-only.
.*currencies.*:USING \(true\)

# ── custom_fields ───────────────────────────────────────────────────────────────
# field_definitions is a configuration table. All authenticated users need
# read access to see field schemas. Write access is admin-only.
.*custom_fields.*:USING \(true\)

# ── drive_config ────────────────────────────────────────────────────────────────
# Drive configuration is a per-entity settings table. All authenticated users
# need read access to discover Drive folder IDs. Write access is admin-only.
.*drive_config.*:USING \(true\)

# ── entities / business_units ────────────────────────────────────────────────────
# These are organizational hierarchy tables. All authenticated users need
# read access to discover entity and business unit structure. Write access
# is admin-only.
.*entities.*:USING \(true\)
.*business_units.*:USING \(true\)

# ── fx_rates ──────────────────────────────────────────────────────────────────
# FX rates is a lookup table for currency conversion. All authenticated users
# need read access to reference exchange rates. Write access is finance/admin only.
.*fx_rates.*:USING \(true\)

# ── relationship_types ─────────────────────────────────────────────────────────
# Relationship types is a lookup table for account relationship vocabulary.
# All authenticated users need read access to discover relationship types.
# Write access is admin-only.
.*relationship_types.*:USING \(true\)

# ── system_settings ───────────────────────────────────────────────────────────
# System-wide configuration table. All authenticated users need read access
# to discover system settings. Write access is admin-only.
.*admin_b_users_roles_access.*:USING \(true\)

# ── notifications & communications ─────────────────────────────────────────────
# notification_routing and email_templates are configuration tables. All
# authenticated users need read access to discover routing rules and
# template content. Write access is admin-only.
.*notification.*:USING \(true\)

# ── user_notifications service_role ────────────────────────────────────────────
# Service role policy for backend notification push. Restricted to service_role
# which bypasses RLS by default; this explicit policy is documentation only.
.*notification.*:WITH CHECK \(true\)

# ── integration config ────────────────────────────────────────────────────────
# Integration settings, connections, and email config are configuration tables.
# All authenticated users need read access to discover integration state and
# configuration. Write access is admin-only.
.*integration_config.*:USING \(true\)

# ── financial_settings ────────────────────────────────────────────────────────
# Financial settings tables (reporting_currency_settings, fiscal_year_settings,
# approval_thresholds, revenue_recognition_defaults). All authenticated users
# need read access. Write access is admin-only.
.*financial_settings.*:USING \(true\)
.*approval_thresholds.*:USING \(true\)
.*fiscal_year.*:USING \(true\)
.*reporting_currency.*:USING \(true\)
.*revenue_recognition.*:USING \(true\)

# ── admin_b_users_roles_access ────────────────────────────────────────────────
# Untracked stray file; users/roles config table uses same pattern as other
# org-level config tables. SELECT for all authenticated, write for admin.
.*admin_b_users_roles_access.*:USING \(true\)

# ── ai_settings ────────────────────────────────────────────────────────────────
# AI settings is a per-entity configuration table. All authenticated users need
# read access to discover AI configuration (provider, model, features). Write
# access is admin-only.
.*ai_settings.*:USING \(true\)

# ── data_management ────────────────────────────────────────────────────────────
# finance_export_config is a per-entity configuration table. All authenticated
# users need read access to discover export configuration. Write is admin-only.
# import_jobs uses (true) only in service_role policies which explicitly
# bypass RLS; they are documentation.
.*data_management.*:USING \(true\)
